# RPC endpoints — these MUST be JSON-RPC *node* URLs (eth_getLogs / eth_getCode), NOT the
# Etherscan REST API. The Etherscan key goes in ETHERSCAN_API_KEY below, not here.
# A free public node that works: https://ethereum-rpc.publicnode.com
RPC_ETHEREUM=https://ethereum-rpc.publicnode.com
RPC_BASE=https://base-mainnet.example/your-key
RPC_ARBITRUM=https://arb-mainnet.example/your-key
RPC_OPTIMISM=https://opt-mainnet.example/your-key
RPC_POLYGON=https://polygon-mainnet.example/your-key

# Polling
POLL_INTERVAL_MS=15000
GETLOGS_MAX_RANGE=2000

# Email alert API (contract TBD — fill in once provided)
EMAIL_API_URL=
EMAIL_API_KEY=
# auth mode: "bearer" | "header" | "body"
EMAIL_API_AUTH_MODE=bearer
# header name when EMAIL_API_AUTH_MODE=header (e.g. x-api-key)
EMAIL_API_AUTH_HEADER=x-api-key

# State file (relative to repo root — never absolute, per OPSEC rules)
STATE_FILE=./state.json

# --- Attribution (npm run attribute) ---
# Etherscan v2 (one key, all chains) — verified ContractName + deployer lookup
ETHERSCAN_API_KEY=
# Arkham entity attribution (optional; granted/paid plan)
ARKHAM_API_KEY=
# Optional local name-tag dataset: JSON map { "0xaddr": "Label" } for real Etherscan-style tags
LABELS_FILE=
# OFAC SDN cache (relative path) + refresh age
OFAC_CACHE=./data/ofac_eth.json
OFAC_MAX_AGE_MS=604800000

# Dune labels (optional). Create the query in dune/label_query.sql, then set its id.
DUNE_API_KEY=
DUNE_LABEL_QUERY_ID=
DUNE_TIMEOUT_MS=60000

# Set ATTRIBUTION=off to disable enriching alert emails with a best-guess project.
ATTRIBUTION=on
